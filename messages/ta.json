  "nodal_data": {
    "a1_name": "Kavitha S.",
    "a1_dept": "சுகாதாரம் & மருத்துவம்",
    "a1_role": "சுகாதார முகாம் பதிவு உதவியாளர்",
    "a1_ai": "வலுவான தமிழ் தொடர்பு திறன் மற்றும் NSS அனுபவம். சுகாதார முகாம் மற்றும் தடுப்பூசி பங்குகளுக்கு நெருக்கமாக பொருந்துகிறது. வார இறுதி பணி அட்டவணையுடன் கிடைக்கும் நேரம் ஒத்துப்போகிறது.",
    "a2_name": "Rajan M.",
    "a2_dept": "கல்வி",
    "a2_role": "கற்பிக்கும் உதவியாளர் (தொடக்க)",
    "a2_ai": "கல்வியில் இளங்கலை பட்டம், தமிழ் மற்றும் ஆங்கிலத்தில் நிறைவான திறன். தகுதி பொருத்தத்தின் அடிப்படையில் தொடக்கப்பள்ளி ஆதரவு பங்குகளுக்கு பரிந்துரைக்கப்படுகிறது.",
    "a3_name": "Meena P.",
    "a3_dept": "சுற்றுச்சூழல் & கடலோரம்",
    "a3_role": "கடற்கரை சுத்தம் தன்னார்வலர்",
    "a3_ai": "அதிக உடல் தகுதி, வெளிப்புற அனுபவம், வார இறுதி கிடைக்கும் நேரம். கடலோர சுத்தம் பணிகளுக்கு வலுவான பொருத்தம். நடமாட்ட கட்டுப்பாடு இல்லை.",
    "a4_name": "Suresh K.",
    "a4_dept": "பேரிடர் மேலாண்மை",
    "a4_role": "வெள்ள நிவாரண விநியோக உதவியாளர்",
    "a4_ai": "உடல் தகுதி மற்றும் அடிப்படை பேரிடர் பயிற்சி முடிந்தது. தளவாட ஒருங்கிணைப்பு பங்குகளுக்கு பொருத்தமானது. வாரநாள் கிடைக்கும் நேரம் குறைவாக உள்ளது.",
    "a5_name": "Priya R.",
    "a5_dept": "சுகாதாரம் & மருத்துவம்",
    "a5_role": "இரத்த தான பிரசாரம் ஒருங்கிணைப்பாளர்",
    "a5_ai": "சுகாதார விழிப்புணர்வுடன் அனுதாப கவனம். முதலுதவி சான்றிதழ் விரும்பத்தக்கது ஆனால் இப்போது இல்லை. பயிற்சி பெற்ற பணியாளர்களுடன் இணைக்க பரிந்துரை.",
    "a6_name": "Anand V.",
    "a6_dept": "சுற்றுலா & கலாச்சாரம்",
    "a6_role": "சுற்றுலா தகவல் வழிகாட்டி",
    "a6_ai": "மூன்று மொழி திறன் (தமிழ், ஆங்கிலம், பிரெஞ்சு), புதுவை பாரம்பரியம் பற்றிய வலுவான அறிவு. சுற்றுலா வழிகாட்டி பங்கிற்கு சிறந்த சுயவிவர பொருத்தம்."
  },
